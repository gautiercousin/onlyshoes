# Configuration de la base de données PostgreSQL
# Copiez ce fichier en .env et modifiez les valeurs selon vos besoins
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sae_database
POSTGRES_USER=sae_user
POSTGRES_PASSWORD=sae_password

# CodeIgniter - Base URL override for Docker (optional)
# Example: APP_BASEURL=http://192.168.1.18:8080/
# APP_BASEURL=
APP_BASEURL=http://localhost:8080/